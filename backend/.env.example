# --- Her Closet backend env ---
MONGO_URL="mongodb://localhost:27017"
DB_NAME="her_closet"
CORS_ORIGINS="*"

# Emergent Universal LLM key (used for Gemini Nano Banana try-on)
# Get yours from Emergent profile → Universal Key
EMERGENT_LLM_KEY="sk-emergent-..."

# JWT — rotate this to a strong random string before any non-local use
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ALGORITHM="HS256"

# Pre-seeded user credentials (re-synced on every backend startup)
ADMIN_EMAIL="admin@hercloset.local"
ADMIN_PASSWORD="adminpass123"
PARTNER_EMAIL="her@hercloset.local"
PARTNER_PASSWORD="herpass123"

# Where activity emails go (leave blank to disable)
ADMIN_NOTIFY_EMAIL=""

# Resend (transactional email). Leave RESEND_API_KEY blank to silently skip emails.
# Get a key at https://resend.com → API Keys
RESEND_API_KEY=""
SENDER_EMAIL="onboarding@resend.dev"
